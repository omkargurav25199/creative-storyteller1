FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY creative_storyteller/ ./creative_storyteller/

ENV PORT=8080
EXPOSE 8080

CMD ["uvicorn", "google.adk.cli.fast_api:get_fast_api_app", "--host", "0.0.0.0", "--port", "8080", "--factory"]
